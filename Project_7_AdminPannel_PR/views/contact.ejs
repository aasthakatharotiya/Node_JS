<style>
    .main-panel {
        position: fixed;
        height: 100%;
        width: 83%;
        overflow: scroll;
        overflow-x: hidden;
        right: 0%;
    }

    .contact_con {

        .c7 {
            height: auto;
            width: 100%;
            /* border: 1px solid; */
        }

        .c8 {
            height: inherit;
            width: 48%;
            display: inline-block;
            /* border: 1px solid; */
        }

        input {
            height: 40px;
            width: 90%;
        }
        textarea{
            width: 90%;
        }

        @media screen and (max-width: 720px) {
            .c7 {
                width: 100%;
            }

            .c8 {
                width: 40%;
            }

            input {
                width: 100%;
            }
        }

        @media screen and (max-width: 480px) {
            .c7 {
                width: 100%;
            }

            .c8 {
                width: 100%;
            }

            input {
                width: 100%;
            }
        }

        .b1 {
            height: 50px;
            width: 150px;
            font-size: 20px;
            background-color: rgb(74,156,206);
            color: white;
            border: none;
        }

        .b1:hover {
            border: 2px solid rgb(74,156,206);
            color: rgb(74,156,206);
            background: none;
        }
    }
</style>

