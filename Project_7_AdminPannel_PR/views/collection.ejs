<!DOCTYPE html>
<html lang="en">

<head>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Breeze Admin</title>
    <link rel="stylesheet" href="assets/vendors/mdi/css/materialdesignicons.min.css" />
    <link rel="stylesheet" href="assets/vendors/flag-icon-css/css/flag-icon.min.css" />
    <link rel="stylesheet" href="assets/vendors/css/vendor.bundle.base.css" />
    <link rel="stylesheet" href="assets/vendors/font-awesome/css/font-awesome.min.css" />
    <link rel="stylesheet" href="assets/vendors/bootstrap-datepicker/bootstrap-datepicker.min.css" />
    <link rel="stylesheet" href="assets/css/style.css" />
    <link rel="shortcut icon" href="assets/images/favicon.png" />


    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
        integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />



    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css"
        integrity="sha512-z3gLpd7yknf1YoNbCzqRKc4qyor8gaKU1qmn+CShxbuBusANI9QpRohGBreCFkKxLhei6S9CQXFEbbKuqLg0DA=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/wow/1.1.2/wow.min.js"
        integrity="sha512-Eak/29OTpb36LLo2r47IpVzPBLXnAMPAVypbSZiZ4Qkf8p/7S/XRG5xp7OKWPPYfJT6metI+IORkR5G8F900+g=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <!-- <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous"> -->
</head>

<style>
    .main-panel {
        position: fixed;
        height: 100%;
        width: 83%;
        overflow: scroll;
        overflow-x: hidden;
        right: 0%;
    }

    .cloth_con {
        width: 100%;
        overflow: hidden;
        /* border: 2px solid; */
        margin-top: -50px;

        .img_left {
            height: 550px;
            width: 80%;
            /* border: 2px solid; */
            overflow: hidden;
            border-radius: 10px;
        }

        .img_left img {
            height: 110%;
            width: 130%;
            margin-top: -10px;
            margin-left: -10px;
        }

        .img_left:hover img {
            margin-left: -50px;
            transition: 2s;
            opacity: 50%;
        }

        .left_text {
            margin-top: -520px;
            text-align: left;
            padding-left: 50px;
        }

        .left_text h1 {
            font-size: 33px;
        }

        .left_text span {
            font-weight: bold;
            letter-spacing: 5px;
            border-bottom: 2px solid;
            padding-bottom: 5px;
        }

        #img_flex_end {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: flex-end;
            /* border: 2px solid; */
        }

        #img_flex {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            /* border: 2px solid; */
        }

        .img_right {
            height: 260px;
            width: 80%;
            /* border: 2px solid; */
            overflow: hidden;
            border-radius: 10px;
        }

        .img_right img {
            height: 110%;
            width: 130%;
            margin-top: -10px;
            margin-left: -10px;
        }

        .img_right:hover img {
            margin-left: -50px;
            transition: 2s;
            opacity: 50%;
        }

        .flex_text_start {
            margin-top: -150px;
            text-align: left;
            padding-left: 50px;
        }

        .flex_text_start h1 {
            font-size: 33px;
        }

        .flex_text_start span {
            font-weight: bold;
            letter-spacing: 5px;
            border-bottom: 2px solid;
            padding-bottom: 5px;
        }


        .flex_text_end {
            margin-top: -150px;
            text-align: right;
            padding-right: 50px;
        }

        .flex_text_end h1 {
            font-size: 33px;
        }

        .flex_text_end span {
            font-weight: bold;
            letter-spacing: 5px;
            border-bottom: 2px solid;
            padding-bottom: 5px;
        }

        @media screen and (max-width: 768px) {
            #img_flex_end {
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                align-items: center;
                /* border: 2px solid; */
            }

            #img_flex {
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                align-items: center;
                /* border: 2px solid; */
            }

            .img_left {
                width: 120%;
            }

            .img_right {
                width: 120%;
                margin: 20px;
            }
        }
    }

    .veg_con {
        .vegetable {
            height: 300px;
            width: 100%;
            overflow: hidden;
            /* border: 2px solid; */
        }

        .vegetable img {
            height: 100%;
            width: 100%;
        }

        #vegetable_height {
            height: 170%;
            margin-top: -50%;
        }

        .vegetable button {
            background-color: rgb(130, 174, 70);
            border: none;
            color: white;
            height: 50px;
            width: 130px;
            font-size: 22px;
        }

        #vegetable_text h1 {
            color: rgb(130, 174, 70);
            font-size: 30px;
        }

        #vegetable_text p {
            color: gray;
        }

        #vegetable_text button {
            border-radius: 30px;
            width: 160px;
        }

        .vegetable:hover img {
            transform: scale(1.2);
            transition: 2s;
            opacity: 70%;
        }
    }
</style>

<body>
    <div class="container-scroller">
        <%- include("aside") %>
            <div class="container-fluid page-body-wrapper">
                <%- include("header") %>

                    <div class="main-panel">
                        <div class="content-wrapper">
                            <div class="cloth_con">
                                <div class="container">
                                    <div class="row">
                                        <div id="img_flex_end"
                                            class="wow animate__animated animate__backInLeft col col-md-6 col-sm-12 mt-5">
                                            <div class="img_left">
                                                <img src="Ex_img/grid_1.jpg" alt="">
                                                <div class="left_text">
                                                    <h1>Toned Collection</h1>
                                                    <span>SHOP NOW</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div id="img_flex"
                                            class="wow animate__animated animate__backInRight col col-md-6 col-sm-12 mt-5">
                                            <div class="img_right">
                                                <img src="Ex_img/grid_2.jpg" alt="">
                                                <div class="flex_text_start">
                                                    <h1>Signature Collection</h1>
                                                    <span>SHOP NOW</span>
                                                </div>
                                            </div>

                                            <div class="img_right">
                                                <img src="Ex_img/grid_3.jpg" alt="">
                                                <div class="flex_text_end">
                                                    <h1>Shorts & Capris</h1>
                                                    <span>SHOP NOW</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <center>
                                <div class="veg_con">
                                    <div class="container mt-4">
                                        <div class="row">
                                            <div
                                                class="mt-5 wow animate__animated animate__backInLeft col col-12 col-md-4 col-sm-12">
                                                <div class="vegetable position-relative">
                                                    <img src="Ex_img/category-1.jpg" alt="">
                                                    <button class="position-absolute bottom-0 start-0">
                                                        Fruits
                                                    </button>
                                                </div>
                                            </div>
                                            <div
                                                class="mt-5 wow animate__animated animate__zoomIn col col-12 col-md-4 col-sm-12">
                                                <div id="vegetable_text" class="vegetable position-relative">
                                                    <h1>Vegetables</h1>
                                                    <p>Protect the health of every home</p>
                                                    <button class="mt-3">Shop Now</button>
                                                </div>
                                            </div>
                                            <div
                                                class="mt-5 wow animate__animated animate__backInRight col col-12 col-md-4 col-sm-12">
                                                <div class="vegetable position-relative">
                                                    <img src="Ex_img/category-3.jpg" alt="">
                                                    <button class="position-absolute bottom-0 start-0">
                                                        Juices
                                                    </button>
                                                </div>
                                            </div>



                                            <div
                                                class="mt-5 wow animate__animated animate__backInLeft col col-12 col-md-4 col-sm-12">
                                                <div class="vegetable position-relative">
                                                    <img src="Ex_img/category-2.jpg" alt="">
                                                    <button class="position-absolute bottom-0 start-0">
                                                        Vegetables
                                                    </button>
                                                </div>
                                            </div>
                                            <div
                                                class="mt-5 wow animate__animated animate__zoomIn col col-12 col-md-4 col-sm-12">
                                                <div class="vegetable position-relative">
                                                    <img id="vegetable_height" src="Ex_img/category.jpg" alt="">
                                                </div>
                                            </div>
                                            <div
                                                class="mt-5 wow animate__animated animate__backInRight col col-12 col-md-4 col-sm-12">
                                                <div class="vegetable position-relative">
                                                    <img src="Ex_img/category-4.jpg" alt="">
                                                    <button class="position-absolute bottom-0 start-0">
                                                        Dried
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </center>
                        </div>

                        <footer class="footer">
                            <div class="d-sm-flex justify-content-center justify-content-sm-between">
                                <span class="text-muted d-block text-center text-sm-left d-sm-inline-block">Copyright ©
                                    bootstrapdash.com 2020</span>
                                <span class="float-none float-sm-right d-block mt-1 mt-sm-0 text-center"> Free <a
                                        href="https://www.bootstrapdash.com/" target="_blank">Bootstrap dashboard
                                        template</a> from Bootstrapdash.com</span>
                            </div>
                        </footer>
                    </div>
                    <!-- main-panel ends -->
            </div>
            <!-- page-body-wrapper ends -->
    </div>
    <!-- container-scroller -->
    <!-- plugins:js -->
    <script src="assets/vendors/js/vendor.bundle.base.js"></script>
    <!-- endinject -->
    <!-- Plugin js for this page -->
    <script src="assets/vendors/chart.js/Chart.min.js"></script>
    <script src="assets/vendors/bootstrap-datepicker/bootstrap-datepicker.min.js"></script>
    <script src="assets/vendors/flot/jquery.flot.js"></script>
    <script src="assets/vendors/flot/jquery.flot.resize.js"></script>
    <script src="assets/vendors/flot/jquery.flot.categories.js"></script>
    <script src="assets/vendors/flot/jquery.flot.fillbetween.js"></script>
    <script src="assets/vendors/flot/jquery.flot.stack.js"></script>
    <script src="assets/vendors/flot/jquery.flot.pie.js"></script>
    <!-- End plugin js for this page -->
    <!-- inject:js -->
    <script src="assets/js/off-canvas.js"></script>
    <script src="assets/js/hoverable-collapse.js"></script>
    <script src="assets/js/misc.js"></script>
    <!-- endinject -->
    <!-- Custom js for this page -->
    <script src="assets/js/dashboard.js"></script>
    <!-- End custom js for this page -->

</body>

</html>